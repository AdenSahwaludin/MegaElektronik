// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int     @id @default(autoincrement())
  name         String
  brand        String
  model        String
  buyPrice     Int     // Cost to business in cents/smallest unit
  askingPrice  Int     // Initial asking price
  fixedPrice   Int     // Fixed/list price
  stock        Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  transactionItems TransactionItem[]

  @@index([name])
  @@index([brand])
}

model Customer {
  id           Int     @id @default(autoincrement())
  name         String
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  transactions Transaction[]

  @@index([name])
}

model Transaction {
  id           Int     @id @default(autoincrement())
  customerId   Int?    // Optional: customer may be anonymous
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  totalAmount  Int     // Total revenue in cents/smallest unit
  totalProfit  Int     // Net profit in cents/smallest unit
  createdAt    DateTime @default(now())

  // Relations
  transactionItems TransactionItem[]

  @@index([customerId])
  @@index([createdAt])
}

model TransactionItem {
  id           Int     @id @default(autoincrement())
  transactionId Int
  transaction  Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  soldPrice    Int     // Final agreed price per unit
  profitPerItem Int    // (soldPrice - buyPrice) per unit

  createdAt    DateTime @default(now())

  @@index([transactionId])
  @@index([productId])
}
