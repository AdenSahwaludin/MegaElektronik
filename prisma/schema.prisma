// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int     @id @default(autoincrement())
  name         String
  brand        String
  model        String
  otherName    String?  // Nama lain untuk pencarian (opsional)
  buyPrice     Int     // Cost to business in cents/smallest unit
  askingPrice  Int     // Initial asking price
  fixedPrice   Int     // Fixed/list price
  stock        Int     @default(0)
  servicePrice Int?
  isActive     Boolean @default(true) // Product status: active or inactive
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  transactionItems TransactionItem[]
  productArrivals  ProductArrival[]

  @@index([name])
  @@index([brand])
  @@index([isActive])
}

model Customer {
  id           Int     @id @default(autoincrement())
  name         String
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  transactions Transaction[]

  @@index([name])
}

model Transaction {
  id           Int     @id @default(autoincrement())
  customerId   Int?    // Optional: customer may be anonymous
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  totalAmount  Int     // Total revenue in cents/smallest unit
  totalProfit  Int     // Net profit in cents/smallest unit
  paidAmount   Int?    // Amount paid by customer in Rupiah/cents (nullable)
  createdAt    DateTime @default(now())

  // Relations
  transactionItems TransactionItem[]

  @@index([customerId])
  @@index([createdAt])
}

model TransactionItem {
  id           Int     @id @default(autoincrement())
  transactionId Int
  transaction  Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId    Int
  product      Product @relation(fields: [productId], references: [id])
  quantity     Int
  soldPrice    Int     // Final agreed price per unit
  profitPerItem Int    // (soldPrice - buyPrice) per unit

  createdAt    DateTime @default(now())

  @@index([transactionId])
  @@index([productId])
}

model ProductArrival {
  id           Int      @id @default(autoincrement())
  productId    Int
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity     Int
  supplier     String?
  buyPrice     Int?     // to keep track if they entered a price, can be null
  askingPrice  Int?
  fixedPrice   Int?
  servicePrice Int?
  notes        String?
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}
